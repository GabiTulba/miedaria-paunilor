# This file contains environment variables expected by the application.
# It should be copied to .env and values should be set appropriately for your environment.

# PostgreSQL database host
POSTGRES_HOST=database

# PostgreSQL database port
POSTGRES_PORT=5432

# PostgreSQL database user
POSTGRES_USER=user

# PostgreSQL database password
POSTGRES_PASSWORD=password

# Default administrator username for initial setup
ADMIN_USERNAME=admin

# Default administrator password for initial setup
ADMIN_PASSWORD=password 

# Full database connection URL (ensure this matches the above settings)
DATABASE_URL=postgres://user:password@database/miedaria_paunilor

# Secret key for JWT token generation and validation
JWT_SECRET=my-super-secret-key

# PostgreSQL database name
POSTGRES_DB=miedaria_paunilor

# Base URL for the frontend to connect to the backend API. MUST BE SET.
# For development with separate frontend/backend servers: http://localhost:8000/api
# For production with Nginx proxy: /api (relative URL)
VITE_API_BASE_URL=/api

# Public site origin used to emit absolute URLs in SEO meta (canonical, hreflang,
# og:image, og:url, JSON-LD). No trailing slash. Must match the canonical host
# (apex, not www). Falls back to window.location.origin when unset, but
# crawlers/link-preview bots see correct values only when this is set.
VITE_SITE_URL=https://miedaria-paunilor.ro

# Port on which the Rust backend server will listen. MUST BE SET.
BACKEND_PORT=8000

# Directory where uploaded images will be stored. MUST BE SET.
IMAGE_UPLOAD_DIR=/app/images

# Number of hours until a generated JWT token expires. MUST BE SET.
JWT_EXPIRATION_HOURS=24

# Allowed CORS origin (frontend URL). Restrict to your domain in production. MUST BE SET.
# Development: https://localhost
# Production: https://yourdomain.com
ALLOWED_ORIGIN=https://localhost
